{% extends 'layout.twig' %}

{% block content %}
	<div class="campaign-steps-section">
		<div class="dashboard-container">
			<div class="campaign-steps-container">
				<div class="campaign-steps-wrapper">
					<div class="campaign-steps-track-wrapper">
						<div class="campaign-progress-track">
							<div class="campaign-progress-fill" style="width: 50%"></div>
						</div>
						
						<div class="campaign-steps-circles">
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">Verenigingsgegevens</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">2</div>
								<p class="campaign-step-label">Vragen</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">3</div>
							<p class="campaign-step-label">E-mail Tekst</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">4</div>
								<p class="campaign-step-label">Ledenlijst</p>
							</div>
						</div>
					</div>

					<form action="/campagne/form/vragen" method="POST">
						<div class="campaign-form-wrapper">
						<div class="campaign-form-header">
							<i data-lucide="help-circle" class="campaign-form-icon"></i>
							<div class="campaign-form-header-text">
								<h2 class="campaign-form-title">Vragen</h2>
								<p class="campaign-form-subtitle">Definieer maximaal 5 ja/nee vragen</p>
							</div>
						</div>

						<p class="campaign-question-instructions">Definieer maximaal 5 vragen die uw leden met Ja of Nee beantwoorden</p>

						<div id="questions-container">
							{% if session.new_campaign.questions is empty %}
								<div class="campaign-question-group" data-question="1">
									<div class="campaign-question-number">1</div>
									<div class="campaign-question-field">
										<textarea 
											id="question-1" 
											name="questions[]" 
											class="campaign-form-input" 
											placeholder="Geeft u toestemming voor het ontvangen van e-mailcommunicatie van onze vereniging?"
											required
											rows="2"
										></textarea>
									</div>
									<div style="width: 24px;"></div>
								</div>
							{% else %}
								{% for question in session.new_campaign.questions %}
									<div class="campaign-question-group" data-question="{{ loop.index }}">
										<div class="campaign-question-number">{{ loop.index }}</div>
										<div class="campaign-question-field">
											<textarea 
												id="question-{{ loop.index }}" 
												name="questions[]" 
												class="campaign-form-input" 
												required
												rows="2"
											>{{ question }}</textarea>
										</div>
										{% if loop.index > 1 %}
											<button type="button" class="question-remove-btn" title="Vraag verwijderen" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 4px; display: flex;">
												<i data-lucide="trash-2" size="20"></i>
											</button>
										{% else %}
											<div style="width: 24px;"></div>
										{% endif %}
									</div>
								{% endfor %}
							{% endif %}
						</div>

						<div class="campaign-form-group" style="margin-top: 20px;">
							<button type="button" class="campaign-add-question-button" id="add-question-btn">
								<i data-lucide="plus" size="17"></i>
								<span>Vraag toevoegen</span>
							</button>
						</div>
					</div>

						<div class="campaign-form-navigation">
							<a href="/campagne/form/verenigingsgegevens" class="campaign-btn-nav campaign-btn-nav-prev">
								<i data-lucide="arrow-left" size="24"></i>
								<span>Vorige</span>
							</a>
							<button type="submit" id="next-btn" class="campaign-btn-nav campaign-btn-nav-next campaign-btn-nav-next-foggy" style="pointer-events: none; border: none; cursor: default;">
								<span>Volgende</span>
								<i data-lucide="arrow-right" size="24"></i>
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>

{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('questions-container');
    const addBtn = document.getElementById('add-question-btn');
    const maxQuestions = 5;

    function updateQuestionNumbers() {
        const groups = container.querySelectorAll('.campaign-question-group');
        groups.forEach((group, index) => {
            const number = index + 1;
            group.setAttribute('data-question', number);
            group.querySelector('.campaign-question-number').textContent = number;
            group.querySelector('textarea').id = `question-${number}`;
            group.querySelector('textarea').placeholder = `Vraag ${number}`;
        });
        
        if (groups.length >= maxQuestions) {
            addBtn.style.display = 'none';
        } else {
            addBtn.style.display = 'inline-flex';
        }
    }

    addBtn.addEventListener('click', () => {
        const currentCount = container.querySelectorAll('.campaign-question-group').length;
        if (currentCount >= maxQuestions) return;

        const groupDiv = document.createElement('div');
        groupDiv.className = 'campaign-question-group';
        groupDiv.style.marginTop = '15px';
        
        groupDiv.innerHTML = `
            <div class="campaign-question-number"></div>
            <div class="campaign-question-field">
                <textarea 
                    name="questions[]" 
                    class="campaign-form-input" 
                    required
                    rows="2"
                ></textarea>
            </div>
            <button type="button" class="question-remove-btn" title="Vraag verwijderen" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 4px; display: flex;">
                <i data-lucide="trash-2" size="20"></i>
            </button>
        `;

        // Add remove functionality
        const removeBtn = groupDiv.querySelector('.question-remove-btn');
        removeBtn.addEventListener('click', () => {
            groupDiv.remove();
            updateQuestionNumbers();
        });

        container.appendChild(groupDiv);
        lucide.createIcons({ root: groupDiv });
        updateQuestionNumbers();
        
        // Focus the new textarea
        groupDiv.querySelector('textarea').focus();
    });

    // Check required fields
    const nextBtn = document.getElementById('next-btn');
    
    function checkRequiredQuestions() {
        const textareas = container.querySelectorAll('.campaign-form-input');
        let allValid = true;
        textareas.forEach(ta => {
            if (ta.value.trim() === '') {
                allValid = false;
            }
        });

        if (allValid && textareas.length > 0) {
            nextBtn.classList.remove('campaign-btn-nav-next-foggy');
            nextBtn.style.pointerEvents = 'auto';
            nextBtn.style.cursor = 'pointer';
        } else {
            nextBtn.classList.add('campaign-btn-nav-next-foggy');
            nextBtn.style.pointerEvents = 'none';
            nextBtn.style.cursor = 'default';
        }
    }

    container.addEventListener('input', checkRequiredQuestions);

        // Add remove functionality for pre-rendered buttons
    container.querySelectorAll('.question-remove-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            this.closest('.campaign-question-group').remove();
            updateQuestionNumbers();
            checkRequiredQuestions();
        });
    });

    checkRequiredQuestions();
});
</script>
{% endblock %}

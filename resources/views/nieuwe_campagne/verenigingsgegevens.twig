{% extends 'layout.twig' %}

{% block content %}
	<div class="campaign-steps-section">
		<div class="dashboard-container">
			<div class="campaign-steps-container">
				<div class="campaign-steps-wrapper">
					<div class="campaign-steps-track-wrapper">
						<div class="campaign-progress-track">
							<div class="campaign-progress-fill" style="width: 25%"></div>
						</div>
						
						<div class="campaign-steps-circles">
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">1</div>
								<p class="campaign-step-label">Verenigingsgegevens</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">2</div>
								<p class="campaign-step-label">Vragen</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">3</div>
								<p class="campaign-step-label">E-mail Teks</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">4</div>
								<p class="campaign-step-label">Ledenlijst</p>
							</div>
						</div>
					</div>

					<div class="campaign-form-wrapper">
						<div class="campaign-form-header">
							<i data-lucide="building-2" class="campaign-form-icon"></i>
							<div class="campaign-form-header-text">
								<h2 class="campaign-form-title">Verenigingsgegevens</h2>
								<p class="campaign-form-subtitle">Basisinformatie voor uw vereniging</p>
							</div>
						</div>

						<div class="campaign-form-group">
							<label for="org-name" class="campaign-form-label">Naam van de vereniging *</label>
							<input 
								type="text" 
								id="org-name" 
								name="org_name" 
								class="campaign-form-input" 
								placeholder="Sport vereniging De Eendracht"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="contact-person" class="campaign-form-label">Contactpersoon *</label>
							<input 
								type="text" 
								id="contact-person" 
								name="contact_person" 
								class="campaign-form-input" 
								placeholder="Van de Vries"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="email" class="campaign-form-label">E-mailadres *</label>
							<input 
								type="email" 
								id="email" 
								name="email" 
								class="campaign-form-input" 
								placeholder="secretaris@vereniging.nl"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="phone" class="campaign-form-label">Telefoonnummer</label>
							<input 
								type="tel" 
								id="phone" 
								name="phone" 
								class="campaign-form-input" 
								placeholder="06-12345678"
							>
						</div>

						<div class="campaign-form-group-toggle">
							<label class="campaign-toggle-switch">
								<input type="checkbox" class="campaign-toggle-input">
								<span class="campaign-toggle-slider"></span>
							</label>
							<span class="campaign-toggle-label">Telefoonnummer tonen in e-mails</span>
						</div>

						<div class="campaign-form-group">
							<label class="campaign-form-label">Logo (.jpg max 2MB, bij voorkeur 200x200px)</label>
							<label class="campaign-upload-button">
								<input type="file" accept=".jpg,.jpeg" style="display: none;">
								<i data-lucide="upload" size="20"></i>
								<span>Upload Logo</span>
							</label>
						</div>
					</div>

					<div class="campaign-form-navigation">
						<button class="campaign-btn-nav campaign-btn-nav-prev">
							<i data-lucide="arrow-left" size="24"></i>
							<span>Vorige</span>
						</button>
						<button class="campaign-btn-nav campaign-btn-nav-next">
							<span>Volgende</span>
							<i data-lucide="arrow-right" size="24"></i>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% extends 'layout.twig' %}

{% block content %}
	<div class="steps-section">
		<div class="dashboard-container">
			<div class="steps-container">
				<div class="steps-wrapper">
					<div class="steps-track-wrapper">
						<div class="progress-track">
							<div class="progress-fill" style="width: 25%"></div>
						</div>
						
						<div class="steps-circles">
							<div class="step-item">
								<div class="step-circle active">1</div>
								<p class="step-label">Verenigingsgegevens</p>
							</div>
							<div class="step-item">
								<div class="step-circle">2</div>
								<p class="step-label">Vragen</p>
							</div>
							<div class="step-item">
								<div class="step-circle">3</div>
								<p class="step-label">E-mail Teks</p>
							</div>
							<div class="step-item">
								<div class="step-circle">4</div>
								<p class="step-label">Ledenlijst</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<style>
		.steps-section {
			padding: 3rem 1rem;
		}

		.steps-container {
			display: flex;
			justify-content: center;
		}

		.steps-wrapper {
			width: 100%;
			max-width: 750px;
		}

		.steps-track-wrapper {
			display: flex;
			flex-direction: column;
			align-items: center;
			margin-bottom: 2rem;
		}

		.progress-track {
			width: calc(100% + 4rem);
			height: 8px;
			background-color: #e5e7eb;
			border-radius: 4px;
			overflow: hidden;
			order: 2;
			margin-left: -2rem;
			margin-right: -2rem;
		}

		.progress-fill {
			height: 100%;
			background-color: #10b981;
			border-radius: 4px;
			width: 25%;
		}

		.steps-circles {
			display: flex;
			justify-content: space-between;
			width: 100%;
			order: 1;
			margin-bottom: 1rem;
		}

		.step-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.75rem;
		}

		.step-circle {
			width: 50px;
			height: 50px;
			border-radius: 50%;
			background-color: #d1d5db;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.25rem;
			font-weight: 600;
			color: #374151;
			flex-shrink: 0;
		}

		.step-circle.active {
			background-color: #10b981;
			color: white;
		}

		.step-label {
			font-size: 0.9rem;
			color: #6b7280;
			font-weight: 500;
			text-align: center;
			margin: 0;
			max-width: 120px;
			white-space: nowrap;
		}
	</style>
{% endblock %}

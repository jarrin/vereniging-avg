{% extends 'layout.twig' %}

{% block content %}
	<div class="campaign-steps-section">
		<div class="dashboard-container">
			<div class="campaign-steps-container">
				<div class="campaign-steps-wrapper">
					<div class="campaign-steps-track-wrapper">
						<div class="campaign-progress-track">
							<div class="campaign-progress-fill" style="width: 25%"></div>
						</div>
						
						<div class="campaign-steps-circles">
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">1</div>
								<p class="campaign-step-label">Verenigingsgegevens</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">2</div>
								<p class="campaign-step-label">Vragen</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">3</div>
								<p class="campaign-step-label">E-mail Teks</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">4</div>
								<p class="campaign-step-label">Ledenlijst</p>
							</div>
						</div>
					</div>

					<div class="campaign-form-wrapper">
						<div class="campaign-form-header">
							<i data-lucide="building-2" class="campaign-form-icon"></i>
							<div class="campaign-form-header-text">
								<h2 class="campaign-form-title">Verenigingsgegevens</h2>
								<p class="campaign-form-subtitle">Basisinformatie voor uw vereniging</p>
							</div>
						</div>

						<div class="campaign-form-group">
							<label for="org-name" class="campaign-form-label">Naam van de vereniging *</label>
							<input 
								type="text" 
								id="org-name" 
								name="org_name" 
								class="campaign-form-input" 
								placeholder="Sport vereniging De Eendracht"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="contact-person" class="campaign-form-label">Contactpersoon *</label>
							<input 
								type="text" 
								id="contact-person" 
								name="contact_person" 
								class="campaign-form-input" 
								placeholder="Van de Vries"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="email" class="campaign-form-label">E-mailadres *</label>
							<input 
								type="email" 
								id="email" 
								name="email" 
								class="campaign-form-input" 
								placeholder="secretaris@vereniging.nl"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="phone" class="campaign-form-label">Telefoonnummer</label>
							<input 
								type="tel" 
								id="phone" 
								name="phone" 
								class="campaign-form-input" 
								placeholder="06-12345678"
							>
						</div>

						<div class="campaign-form-group-toggle">
							<label class="campaign-toggle-switch">
								<input type="checkbox" class="campaign-toggle-input">
								<span class="campaign-toggle-slider"></span>
							</label>
							<span class="campaign-toggle-label">Telefoonnummer tonen in e-mails</span>
						</div>

						<div class="campaign-form-group">
							<label class="campaign-form-label">Logo (.jpg max 2MB, bij voorkeur 200x200px)</label>
							<div class="logo-upload-wrapper">
								<label class="campaign-upload-button">
									<input type="file" id="logo-upload-input" accept=".jpg,.jpeg,.png" style="display: none;">
									<i data-lucide="upload" size="20"></i>
									<span>Kies Logo</span>
								</label>
								<div class="logo-preview-container" id="logo-preview-container" style="display: none;">
									<img id="logo-preview-image" src="" alt="Logo preview">
									<button type="button" class="logo-remove-btn" id="logo-remove-btn" aria-label="Verwijder logo">
										<i data-lucide="x" size="16"></i>
									</button>
								</div>
							</div>
						</div>
					</div>

					<div class="campaign-form-navigation">
					<a href="#" class="campaign-btn-nav campaign-btn-nav-prev" style="cursor: not-allowed; opacity: 0.5;">
						<i data-lucide="arrow-left" size="24"></i>
						<span>Vorige</span>
					</a>
				<a href="/campagne/form/vragen" class="campaign-btn-nav campaign-btn-nav-next campaign-btn-nav-next-foggy">
						<span>Volgende</span>
						<i data-lucide="arrow-right" size="24"></i>
					</a>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const fileInput = document.getElementById('logo-upload-input');
    const previewContainer = document.getElementById('logo-preview-container');
    const previewImage = document.getElementById('logo-preview-image');
    const removeBtn = document.getElementById('logo-remove-btn');
    const uploadLabel = document.querySelector('.campaign-upload-button');

    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        
        if (file) {
            // Check file size (max 2MB)
            if (file.size > 2 * 1024 * 1024) {
                alert('Het geselecteerde bestand is groter dan 2MB. Kies een kleiner bestand.');
                fileInput.value = '';
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                previewImage.src = e.target.result;
                previewContainer.style.display = 'block';
                // Hide the upload button since we have a preview
                uploadLabel.style.display = 'none';
            }
            reader.readAsDataURL(file);
        }
    });

    removeBtn.addEventListener('click', function() {
        fileInput.value = '';
        previewImage.src = '';
        previewContainer.style.display = 'none';
        uploadLabel.style.display = 'flex'; // show the upload button again
    });
});
{% endblock %}

{% extends 'layout.twig' %}

{% block content %}
	<div class="campaign-steps-section">
		<div class="dashboard-container">
			<div class="campaign-steps-container">
				<div class="campaign-steps-wrapper">
					<div class="campaign-steps-track-wrapper">
						<div class="campaign-progress-track">
							<div class="campaign-progress-fill" style="width: 75%"></div>
						</div>
						
						<div class="campaign-steps-circles">
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">Verenigingsgegevens</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">Vragen</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">3</div>
								<p class="campaign-step-label">E-mail Tekst</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle">4</div>
								<p class="campaign-step-label">Ledenlijst</p>
							</div>
						</div>
					</div>

					<form action="/campagne/form/email-tekst" method="POST">
						<div class="campaign-form-wrapper">
						<div class="campaign-form-header">
							<i data-lucide="mail" class="campaign-form-icon"></i>
							<div class="campaign-form-header-text">
								<h2 class="campaign-form-title">E-mail Tekst</h2>
								<p class="campaign-form-subtitle">Stel uw e-mail tekst samen</p>
							</div>
						</div>

						<div class="campaign-form-group">
							<div class="campaign-available-variables">
								<span class="variables-label-inline">Beschikbare variabelen</span>
								<div class="variables-list">
									<span class="variable-tag">{naam}</span>
									<span class="variable-tag">{verenigingsnaam}</span>
									<span class="variable-tag">{contactpersoon}</span>
									<span class="variable-tag">{link}</span>
									<span class="variable-tag">{einddatum}</span>
								</div>
							</div>
						</div>

						<div class="campaign-form-group">
							<label for="email-template" class="campaign-form-label">Voorbeeld e-mail laden</label>
							<div class="campaign-dropdown-wrapper">
								<select id="email-template" name="email_template" class="campaign-form-dropdown" onchange="laadVoorbeeldTekst(this.value)">
									<option value="">Kies een voorbeeld...</option>
									<option value="template1">Voorbeeld 1 – Formeel</option>
									<option value="template2">Voorbeeld 2 – Vriendelijk</option>
									<option value="template3">Voorbeeld 3 – Kort & bondig</option>
									<option value="template4">Voorbeeld 4 – Uitgebreid</option>
								</select>
								<i data-lucide="chevron-down" class="dropdown-icon"></i>
							</div>
						</div>

						<div class="campaign-form-group">
					<label for="reply-to-email" class="campaign-form-label">Reply-To e-mailadres vereniging *</label>
								<input 
									type="email" 
									id="reply-to-email" 
									name="reply_to_email" 
									class="campaign-form-input" 
									placeholder="secretaris@vereniging.nl"
									value="{{ session.new_campaign.reply_to_email|default('') }}"
									required
								>
					<span id="email-error" class="form-error-msg" style="display: none; color: #ef4444; font-size: 0.8rem; margin-top: 5px;">Voer een geldig e-mailadres in a.u.b.</span>
					<p class="campaign-form-hint">Reacties van leden worden naar dit adres gestuurd.</p>
				</div>

				<div class="campaign-form-group">
					<label for="email-subject" class="campaign-form-label">Onderwerp eerste e-mail *</label>
							<input 
								type="text" 
								id="email-subject" 
								name="email_subject" 
								class="campaign-form-input" 
								placeholder="Uw jaarlijkse toestemming - {verenigingsnaam}"
								value="{{ session.new_campaign.email_subject|default('') }}"
								required
							>
						</div>

						<div class="campaign-form-group">
							<label for="email-body" class="campaign-form-label">Tekst eerste e-mail *</label>
							<textarea 
								id="email-body" 
								name="email_body" 
								class="campaign-form-input" 
								placeholder="Beste {naam}, ..."
								rows="8"
								required
							>{{ session.new_campaign.email_body|default('') }}</textarea>
						</div>

						<div class="campaign-form-group">
							<label for="action-no-response" class="campaign-form-label">Actie bij geen reactie</label>
							<div class="campaign-dropdown-wrapper">
								<select id="action-no-response" name="action_no_response" class="campaign-form-dropdown">
									<option value="no_action" {{ session.new_campaign.action_no_response == 'no_action' ? 'selected' : '' }}>Geen actie</option>
									<option value="reminder" {{ session.new_campaign.action_no_response == 'reminder' ? 'selected' : '' }}>Herinnering sturen</option>
									<option value="default_no" {{ session.new_campaign.action_no_response == 'default_no' ? 'selected' : '' }}>Automatisch op 'Nee' zetten (Default to No)</option>
								</select>
								<i data-lucide="chevron-down" class="dropdown-icon"></i>
							</div>
						</div>

						<div class="campaign-form-group">
							<label for="reminder-subject" class="campaign-form-label">Onderwerp herinnering</label>
							<input 
								type="text" 
								id="reminder-subject" 
								name="reminder_subject" 
								class="campaign-form-input" 
								placeholder="Herinnering: Toestemming bevestigen - {verenigingsnaam}"
								value="{{ session.new_campaign.reminder_subject|default('') }}"
							>
						</div>

						<div class="campaign-form-group">
							<label for="email-signature" class="campaign-form-label">Tekst herinnering</label>
							<textarea 
								id="email-signature" 
								name="email_signature" 
								class="campaign-form-input" 
								placeholder="Beste {naam}, ..."
								rows="7"
							>{{ session.new_campaign.email_signature|default('') }}</textarea>
						</div>

						<div class="campaign-form-group">
							<label for="reminder-days" class="campaign-form-label">Herinnering na (dagen)</label>
							<input 
								type="number" 
								id="reminder-days" 
								name="reminder_days" 
								class="campaign-form-input" 
								placeholder="7"
								value="7"
							>
						</div>
					</div>

						<div class="campaign-form-navigation">
							<a href="/campagne/form/vragen" class="campaign-btn-nav campaign-btn-nav-prev">
								<i data-lucide="arrow-left" size="24"></i>
								<span>Vorige</span>
							</a>
							<button type="submit" id="next-btn" class="campaign-btn-nav campaign-btn-nav-next campaign-btn-nav-next-foggy" style="pointer-events: none; border: none; cursor: default;">
								<span>Volgende</span>
								<i data-lucide="arrow-right" size="24"></i>
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block scripts %}
<script>
	const voorbeeldTeksten = {
		template1: {
			subject: 'Uw jaarlijkse toestemming – {verenigingsnaam}',
			body: `Geachte {naam},

Jaarlijks zijn wij als {verenigingsnaam} verplicht uw toestemming te verlengen voor het verwerken van uw persoonsgegevens conform de Algemene Verordening Gegevensbescherming (AVG).

Wij verzoeken u vriendelijk de bijgevoegde vragen te beantwoorden via onderstaande link:

{link}

Dit neemt slechts enkele minuten van uw tijd in beslag. Uw medewerking wordt zeer op prijs gesteld.

Met vriendelijke groet,
{contactpersoon}
{verenigingsnaam}`,
			herinnering: `Geachte {naam},

Kort geleden ontving u een verzoek om uw toestemming te verlengen voor de verwerking van uw persoonsgegevens door {verenigingsnaam}. Tot op heden hebben wij nog geen reactie van u ontvangen.

Wij verzoeken u vriendelijk alsnog te reageren vóór {einddatum} via:

{link}

Met vriendelijke groet,
{contactpersoon}
{verenigingsnaam}`,
			herinnering_subject: 'Herinnering: Toestemming vereist – {verenigingsnaam}'
		},
		template2: {
			subject: 'Even je toestemming doorgeven – {verenigingsnaam}',
			body: `Hoi {naam},

We zijn weer bij! Elk jaar vragen we onze leden even om toestemming te geven voor het gebruik van hun gegevens. Dat is ook dit jaar niet anders.

Klik op de link hieronder en beantwoord een paar korte vragen. Het kost je echt maar een minuutje:

{link}

Bedankt alvast!

Groeten,
{contactpersoon}
{verenigingsnaam}`,
			herinnering: `Hoi {naam},

We hebben je toestemming nog niet ontvangen. Geen zorgen, het is nog niet te laat!

Klik snel op de link en geef je toestemming door vóór {einddatum}:

{link}

Groeten,
{contactpersoon}`,
			herinnering_subject: 'Herinnering – even je toestemming doorgeven!'
		},
		template3: {
			subject: 'Actie vereist: Toestemming AVG – {verenigingsnaam}',
			body: `Beste {naam},

We hebben uw toestemming nodig voor de verwerking van uw gegevens.

Reageer via: {link}

Deadline: {einddatum}

Met groet,
{contactpersoon}`,
			herinnering: `Beste {naam},

U heeft nog niet gereageerd. Reageer vóór {einddatum} via:

{link}

Met groet,
{contactpersoon}`,
			herinnering_subject: 'Herinnering: Actie vereist – {verenigingsnaam}'
		},
		template4: {
			subject: 'Belangrijke mededeling: Jaarlijkse AVG-toestemming – {verenigingsnaam}',
			body: `Beste {naam},

Als lid van {verenigingsnaam} verwerken wij een aantal persoonsgegevens van u, zoals uw naam, adres en contactgegevens. Dit doen wij om de activiteiten van de vereniging goed te kunnen organiseren en om u op de hoogte te houden van relevante informatie.

Op grond van de Algemene Verordening Gegevensbescherming (AVG) zijn wij verplicht om jaarlijks uw toestemming hiervoor te vernieuwen. Wij vragen u dan ook vriendelijk om onderstaande vragen te beantwoorden.

Klik op de link hieronder om te beginnen:

{link}

Het invullen duurt slechts enkele minuten. Mocht u vragen hebben over de verwerking van uw gegevens, dan kunt u contact opnemen met {contactpersoon}.

Met vriendelijke groet,
{contactpersoon}
{verenigingsnaam}`,
			herinnering: `Beste {naam},

Enkele dagen geleden ontving u een e-mail van {verenigingsnaam} met het verzoek uw toestemming te geven voor de verwerking van uw persoonsgegevens. Wij hebben gemerkt dat u nog niet heeft gereageerd.

Wij begrijpen dat het druk kan zijn, maar wij vragen u vriendelijk dit alsnog te doen vóór {einddatum}. Zonder uw toestemming zijn wij helaas verplicht uw gegevens uit onze systemen te verwijderen.

Klik hier om te reageren:

{link}

Hartstikke bedankt voor uw medewerking!

Met vriendelijke groet,
{contactpersoon}
{verenigingsnaam}`,
			herinnering_subject: 'Laatste herinnering: Uw toestemming is nog vereist – {verenigingsnaam}'
		}
	};

	function laadVoorbeeldTekst(template) {
		if (!template || !voorbeeldTeksten[template]) return;

		const data = voorbeeldTeksten[template];
		document.getElementById('email-subject').value = data.subject;
		document.getElementById('email-body').value = data.body;
		document.getElementById('reminder-subject').value = data.herinnering_subject;
		document.getElementById('email-signature').value = data.herinnering;
		
		checkRequiredFields(); // Re-validate after loading template
	}

	// Dynamic validation
	const nextBtn = document.getElementById('next-btn');
	const replyTo = document.getElementById('reply-to-email');
	const emailError = document.getElementById('email-error');
	const subject = document.getElementById('email-subject');
	const body = document.getElementById('email-body');

	function checkRequiredFields() {
		const isReplyValid = replyTo.value.trim() !== '' && replyTo.validity.valid;
		const isSubjectValid = subject.value.trim() !== '';
		const isBodyValid = body.value.trim() !== '';

		if (isReplyValid && isSubjectValid && isBodyValid) {
			nextBtn.classList.remove('campaign-btn-nav-next-foggy');
			nextBtn.style.pointerEvents = 'auto';
			nextBtn.style.cursor = 'pointer';
		} else {
			nextBtn.classList.add('campaign-btn-nav-next-foggy');
			nextBtn.style.pointerEvents = 'none';
			nextBtn.style.cursor = 'default';
		}

		// Validation message
		if (replyTo.value.trim() !== '' && !replyTo.validity.valid) {
			emailError.style.display = 'block';
			replyTo.style.borderColor = '#ef4444';
		} else {
			emailError.style.display = 'none';
			replyTo.style.borderColor = '';
		}
	}

	[replyTo, subject, body].forEach(input => {
		input.addEventListener('input', checkRequiredFields);
	});
	
	// Also check when template is loaded or on page load
	document.addEventListener('DOMContentLoaded', checkRequiredFields);
</script>
{% endblock %}

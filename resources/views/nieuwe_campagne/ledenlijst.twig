{% extends 'layout.twig' %}

{% block content %}
	<div class="campaign-steps-section">
		<div class="dashboard-container">
			<div class="campaign-steps-container">
				<div class="campaign-steps-wrapper">
					<div class="campaign-steps-track-wrapper">
						<div class="campaign-progress-track">
							<div class="campaign-progress-fill" style="width: 100%"></div>
						</div>
						
						<div class="campaign-steps-circles">
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">Verenigingsgegevens</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">Vragen</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">
									<i data-lucide="check-circle" size="24"></i>
								</div>
								<p class="campaign-step-label">E-mail Tekst</p>
							</div>
							<div class="campaign-step-item">
								<div class="campaign-step-circle active">4</div>
								<p class="campaign-step-label">Ledenlijst</p>
							</div>
						</div>
					</div>

					<form action="/campagne/form/ledenlijst" method="POST" enctype="multipart/form-data">
						<input type="hidden" name="{{ csrf_field_name }}" value="{{ csrf_token }}">
					<div class="campaign-form-wrapper">
						<div class="campaign-form-header">
							<i data-lucide="users" class="campaign-form-icon"></i>
							<div class="campaign-form-header-text">
								<h2 class="campaign-form-title">Ledenlijst</h2>
								<p class="campaign-form-subtitle">Upload uw ledenbestand</p>
							</div>
						</div>

						{% if error %}
						<div class="error-message" style="color: red; margin-bottom: 1rem;">{{ error }}</div>
						{% endif %}

						<div class="campaign-form-group">
							<div class="campaign-available-variables">
								<span class="variables-label-inline">Bestandsformaat</span>
								<p class="file-format-description">Upload een Excel (.xlsx) of CSV bestand met twee kolommen: <strong>Naam</strong> en <strong>E-mail</strong>.</p>
								<table class="file-format-table">
									<thead>
										<tr>
											<th>Naam</th>
											<th>Email</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td>Jan de Vries</td>
											<td>jan@voorbeeld.nl</td>
										</tr>
										<tr>
											<td>Marie Jansen</td>
											<td>marie@voorbeeld.nl</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>

						<div class="campaign-form-group">
							<label class="campaign-form-label">Recipiënten toevoegen</label>
							<div class="input-selection-tabs" style="display: flex; gap: 1rem; margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0;">
								<button type="button" class="tab-btn active" data-target="upload-area" style="padding: 0.5rem 1rem; border: none; background: none; border-bottom: 2px solid var(--primary); cursor: pointer; font-weight: 500;">Bestand uploaden</button>
								<button type="button" class="tab-btn" data-target="manual-area" style="padding: 0.5rem 1rem; border: none; background: none; border-bottom: 2px solid transparent; cursor: pointer; font-weight: 500; color: #64748b;">Handmatig plakken</button>
							</div>

							<div id="upload-area-container">
								<label for="member-list" class="campaign-upload-area">
									<input type="file" id="member-list" name="member_list" accept=".csv,.xlsx,.xls" style="display: none;">
									<i data-lucide="upload" size="40" id="upload-icon"></i>
									<span class="upload-text" id="upload-text">Klik om een Excel of CSV bestand te uploaden</span>
									<span id="selected-file-name" style="display: none; font-weight: 600; color: var(--primary); margin-top: 5px;"></span>
								</label>
							</div>

							<div id="manual-area-container" style="display: none;">
								<textarea id="manual-list" name="manual_list" class="campaign-form-input" style="height: 150px; font-family: monospace; font-size: 0.9rem;" placeholder="Naam, Email&#10;Jan Jansen, jan@voorbeeld.nl&#10;Marie de Vries, marie@test.com"></textarea>
								<p class="form-hint" style="font-size: 0.8rem; color: #64748b; margin-top: 0.5rem;">Eén persoon per regel, gescheiden door een komma.</p>
							</div>
						</div>

						<div class="campaign-form-group">
							<label for="end-date" class="campaign-form-label">Einddatum Campagne *</label>
							<input 
								type="date" 
								id="end-date" 
								name="end_date" 
								class="campaign-form-date"
								required
							>
						</div>
					</div>

						<div class="campaign-form-navigation">
							<a href="/campagne/form/email-tekst" class="campaign-btn-nav campaign-btn-nav-prev">
								<i data-lucide="arrow-left" size="24"></i>
								<span>Vorige</span>
							</a>
							<button type="submit" class="campaign-btn-nav campaign-btn-nav-next campaign-btn-nav-next-foggy" id="submit-campaign-btn" disabled style="border: none; cursor: default;">
								<span>Campagne Aanmaken</span>
							</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>

{% endblock %}

{% block scripts %}
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			// Handle File Upload display
			const memberListInput = document.getElementById('member-list');
			const manualListInput = document.getElementById('manual-list');
			const uploadText = document.getElementById('upload-text');
			const selectedFileName = document.getElementById('selected-file-name');
			const uploadIcon = document.getElementById('upload-icon');
			const submitBtn = document.getElementById('submit-campaign-btn');
			const dateInput = document.getElementById('end-date');
			const tabBtns = document.querySelectorAll('.tab-btn');
			const uploadContainer = document.getElementById('upload-area-container');
			const manualContainer = document.getElementById('manual-area-container');

			tabBtns.forEach(btn => {
				btn.addEventListener('click', () => {
					const target = btn.getAttribute('data-target');
					tabBtns.forEach(b => {
						b.classList.remove('active');
						b.style.borderBottomColor = 'transparent';
						b.style.color = '#64748b';
					});
					btn.classList.add('active');
					btn.style.borderBottomColor = 'var(--primary)';
					btn.style.color = 'var(--text-main)';

					if (target === 'upload-area') {
						uploadContainer.style.display = 'block';
						manualContainer.style.display = 'none';
					} else {
						uploadContainer.style.display = 'none';
						manualContainer.style.display = 'block';
					}
					checkFormReady();
				});
			});

			function checkFormReady() {
				const hasFile = memberListInput.files.length > 0;
				const hasManual = manualListInput.value.trim() !== '';
				const hasDate = dateInput.value.trim() !== '' && dateInput.value !== 'dd-mm-jjjj';
				
				const isUploadVisible = uploadContainer.style.display !== 'none';
				const isDataPresent = isUploadVisible ? hasFile : hasManual;

				if (isDataPresent && hasDate) {
					submitBtn.disabled = false;
					submitBtn.classList.remove('campaign-btn-nav-next-foggy');
					submitBtn.style.cursor = 'pointer';
				} else {
					submitBtn.disabled = true;
					submitBtn.classList.add('campaign-btn-nav-next-foggy');
					submitBtn.style.cursor = 'default';
				}
			}

			manualListInput.addEventListener('input', checkFormReady);
			memberListInput.addEventListener('change', function(e) {
				const file = e.target.files[0];
				if (file) {
					const validTypes = ['text/csv', 'application/vnd.ms-excel', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'];
					const validExtensions = ['.csv', '.xls', '.xlsx'];
					const fileExtension = file.name.substring(file.name.lastIndexOf('.')).toLowerCase();
					
					if (validTypes.includes(file.type) || validExtensions.includes(fileExtension)) {
						uploadText.style.display = 'none';
						uploadIcon.setAttribute('data-lucide', 'file-spreadsheet');
						uploadIcon.style.color = 'var(--primary)';
						lucide.createIcons();
						selectedFileName.textContent = file.name + ' geselecteerd';
						selectedFileName.style.display = 'block';
					} else {
						alert('Kies een geldig .csv of .xlsx bestand a.u.b.');
						memberListInput.value = '';
						selectedFileName.style.display = 'none';
						uploadText.style.display = 'block';
					}
				}
				checkFormReady();
			});

			dateInput.addEventListener('input', checkFormReady);
			dateInput.addEventListener('change', checkFormReady);

			if (!dateInput) return;

			const template = 'dd-mm-jjjj';
			const mask = ['d', 'd', '-', 'm', 'm', '-', 'j', 'j', 'j', 'j'];
			const positions = { digits: [0, 1, 3, 4, 6, 7, 8, 9] };

			let currentMonth = new Date().getMonth();
			let currentYear = new Date().getFullYear();

			// Initialize month and year selects
			function initSelects() {
				const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
				months.forEach((month, index) => {
					const option = document.createElement('option');
					option.value = index;
					option.textContent = month;
					option.selected = index === currentMonth;
					calendarMonth.appendChild(option);
				});

				for (let year = 1900; year <= 2100; year++) {
					const option = document.createElement('option');
					option.value = year;
					option.textContent = year;
					option.selected = year === currentYear;
					calendarYear.appendChild(option);
				}
			}

			// Render calendar days
			function renderCalendar() {
				calendarDaysContainer.innerHTML = '';
				const firstDay = new Date(currentYear, currentMonth, 1).getDay();
				const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
				const daysInPrevMonth = new Date(currentYear, currentMonth, 0).getDate();

				// Previous month days
				for (let i = (firstDay === 0 ? 6 : firstDay - 1); i > 0; i--) {
					const dayEl = document.createElement('div');
					dayEl.className = 'calendar-day other-month';
					dayEl.textContent = daysInPrevMonth - i + 1;
					calendarDaysContainer.appendChild(dayEl);
				}

				// Current month days
				for (let day = 1; day <= daysInMonth; day++) {
					const dayEl = document.createElement('div');
					dayEl.className = 'calendar-day';
					dayEl.textContent = day;

					const today = new Date();
					if (day === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear()) {
						dayEl.classList.add('today');
					}

					dayEl.addEventListener('click', () => selectDate(day));
					calendarDaysContainer.appendChild(dayEl);
				}

				// Next month days
				const totalCells = calendarDaysContainer.children.length;
				for (let day = 1; totalCells + day <= 42; day++) {
					const dayEl = document.createElement('div');
					dayEl.className = 'calendar-day other-month';
					dayEl.textContent = day;
					calendarDaysContainer.appendChild(dayEl);
				}
			}

			function selectDate(day) {
				const date = String(day).padStart(2, '0');
				const month = String(currentMonth + 1).padStart(2, '0');
				const year = currentYear;
				dateInput.value = `${date}-${month}-${year}`;
				calendarPopup.classList.remove('active');
			}

			// Event listeners
			datePickerBtn.addEventListener('click', () => {
				calendarPopup.classList.toggle('active');
				if (calendarPopup.classList.contains('active')) {
					currentMonth = new Date().getMonth();
					currentYear = new Date().getFullYear();
					calendarMonth.value = currentMonth;
					calendarYear.value = currentYear;
					renderCalendar();
				}
			});

			calendarMonth.addEventListener('change', (e) => {
				currentMonth = parseInt(e.target.value);
				renderCalendar();
			});

			calendarYear.addEventListener('change', (e) => {
				currentYear = parseInt(e.target.value);
				renderCalendar();
			});

			// Date mask functionality
			function getValueArray() {
				return (dateInput.value || template).split('');
			}

			function setValueFromArray(arr) {
				dateInput.value = arr.join('');
			}

			dateInput.addEventListener('keydown', function(e) {
				const key = e.key;
				const cursorPos = this.selectionStart;
				const valueArr = getValueArray();

				// Handle Backspace
				if (key === 'Backspace') {
					e.preventDefault();
					if (cursorPos > 0) {
						let pos = cursorPos - 1;
						while (pos >= 0 && !positions.digits.includes(pos)) {
							pos--;
						}
						if (pos >= 0 && positions.digits.includes(pos)) {
							valueArr[pos] = mask[pos];
							setValueFromArray(valueArr);
							this.setSelectionRange(pos, pos);
						}
					}
					return;
				}

				// Handle Delete
				if (key === 'Delete') {
					e.preventDefault();
					if (cursorPos < template.length) {
						let pos = cursorPos;
						while (pos < template.length && !positions.digits.includes(pos)) {
							pos++;
						}
						if (pos < template.length && positions.digits.includes(pos)) {
							valueArr[pos] = mask[pos];
							setValueFromArray(valueArr);
							this.setSelectionRange(cursorPos, cursorPos);
						}
					}
					return;
				}

				// Allow navigation and special keys
				if (['ArrowLeft', 'ArrowRight', 'Tab', 'Shift', 'Control', 'Alt'].includes(key)) {
					return;
				}

				// Only allow numbers
				if (!/^\d$/.test(key)) {
					e.preventDefault();
					return;
				}

				e.preventDefault();

				// Find next digit position from cursor
				let targetPos = cursorPos;
				while (targetPos < mask.length && !positions.digits.includes(targetPos)) {
					targetPos++;
				}

				if (targetPos < mask.length) {
					valueArr[targetPos] = key;
					setValueFromArray(valueArr);
					
					let nextPos = targetPos + 1;
					while (nextPos < mask.length && !positions.digits.includes(nextPos)) {
						nextPos++;
					}
					this.setSelectionRange(nextPos, nextPos);
				}
			});

			dateInput.addEventListener('focus', function() {
				if (this.value === template || !this.value) {
					this.value = template;
					this.setSelectionRange(0, 0);
				}
			});
		});
	</script>

	<script>
		lucide.createIcons();
	</script>
{% endblock %}

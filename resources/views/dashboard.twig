{% extends 'layout.twig' %}

{% block bodyClass %}page-dashboard{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block content %}

<!-- Mobile topbar (only visible on small screens) -->
<div class="mobile-topbar">
    <a href="/dashboard" class="mobile-topbar-brand">
        <i data-lucide="shield-check"></i>
        <span>AVG Verenigingen</span>
    </a>
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu openen">
        <i data-lucide="menu"></i>
    </button>
</div>

<!-- Sidebar overlay backdrop -->
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<div class="app-shell">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <a href="/dashboard" class="sidebar-brand">
            <i data-lucide="shield-check"></i>
            <span>AVG Verenigingen</span>
        </a>
            <!-- Close button, only visible on mobile -->
            <button class="sidebar-close-btn" id="sidebarCloseBtn" aria-label="Menu sluiten">
                <i data-lucide="x"></i>
            </button>


        <nav class="sidebar-nav">
            <a href="/dashboard" class="sidebar-link active">
                <i data-lucide="layout-dashboard"></i>
                <span>Dashboard</span>
            </a>
            <a href="/campagne/nieuw" class="sidebar-link">
                <i data-lucide="plus-circle"></i>
                <span>Nieuwe campagne</span>
            </a>
            <a href="#" class="sidebar-link">
                <i data-lucide="bar-chart-2"></i>
                <span>Rapportages</span>
            </a>
            <a href="/instellingen" class="sidebar-link">
                <i data-lucide="settings"></i>
                <span>Instellingen</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-avatar">
                    <i data-lucide="user"></i>
                </div>
                <div class="sidebar-user-info">
                    <p class="sidebar-user-name">Secretaris</p>
                    <p class="sidebar-user-email">vereniging@avg.nl</p>
                </div>
            </div>
            <a href="/logout" class="sidebar-logout" title="Uitloggen">
                <i data-lucide="log-out"></i>
            </a>
        </div>
    </aside>

    <!-- Main content -->
    <div class="main-content">

        <!-- Top bar -->
        <div class="topbar">
            <div class="topbar-left">
                <h1 class="topbar-title">Dashboard</h1>
                <p class="topbar-subtitle">Beheer uw toestemmingscampagnes</p>
            </div>
            <div class="topbar-right">
                <a href="/campagne/nieuw" class="btn btn-primary btn-new-campaign">
                    <i data-lucide="plus" size="18"></i>
                    Nieuwe campagne
                </a>
            </div>
        </div>

        <!-- Stats row -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-card-icon icon-teal">
                    <i data-lucide="users"></i>
                </div>
                <div class="stat-card-body">
                    <p class="stat-card-label">Totaal leden</p>
                    <p class="stat-card-value">{{ total_members }}</p>
                </div>
                <div class="stat-card-trend trend-up">
                    <i data-lucide="trending-up" size="14"></i>
                    <span>+12%</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-card-icon icon-green">
                    <i data-lucide="check-circle-2"></i>
                </div>
                <div class="stat-card-body">
                    <p class="stat-card-label">Gereageerd</p>
                    <p class="stat-card-value">307</p>
                </div>
                <div class="stat-card-trend trend-up">
                    <i data-lucide="trending-up" size="14"></i>
                    <span>84%</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-card-icon icon-blue">
                    <i data-lucide="mail"></i>
                </div>
                <div class="stat-card-body">
                    <p class="stat-card-label">Actieve campagnes</p>
                    <p class="stat-card-value">{{ campaigns|length }}</p>
                </div>
                <div class="stat-card-trend trend-neutral">
                    <i data-lucide="minus" size="14"></i>
                    <span>Stabiel</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-card-icon icon-orange">
                    <i data-lucide="clock"></i>
                </div>
                <div class="stat-card-body">
                    <p class="stat-card-label">Wacht op reactie</p>
                    <p class="stat-card-value">58</p>
                </div>
                <div class="stat-card-trend trend-down">
                    <i data-lucide="trending-down" size="14"></i>
                    <span>16%</span>
                </div>
            </div>
        </div>

        <!-- Section header -->
        <div class="section-title-bar">
            <h2 class="section-title-text">Campagnes</h2>
            <span class="section-badge">{{ campaigns|length }} totaal</span>
        </div>

        <!-- Campaign cards -->
        <div class="campaign-cards">
            {% if message == 'campaign_created' %}
                <div style="background-color: #dcfce7; color: #166534; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; width: 100%; grid-column: 1 / -1;">
                    <i data-lucide="check-circle" size="18"></i>
                    <span>Campagne succesvol aangemaakt! De e-mails worden verstuurd.</span>
                </div>
            {% endif %}

            {% for campaign in campaigns %}
                <div class="campaign-card {% if campaign.status == 'draft' %}campaign-card-draft{% endif %}">
                    <div class="campaign-card-header">
                        <div class="campaign-card-meta">
                            <span class="status-pill pill-{% if campaign.status == 'active' %}active{% elseif campaign.status == 'completed' %}completed{% else %}draft{% endif %}">
                                <span class="pill-dot"></span>
                                {{ (campaign.status == 'active' ? 'Actief' : (campaign.status == 'completed' ? 'Afgerond' : 'Concept')) }}
                            </span>
                            <span class="campaign-card-date">
                                <i data-lucide="calendar" size="13"></i>
                                Deadline: {{ campaign.end_date ? campaign.end_date|date('d-m-Y') : 'Geen' }}
                            </span>
                        </div>
                        <div class="campaign-card-actions">
                            <a href="/campagne/edit/{{ campaign.id }}" class="icon-btn" title="Bewerken">
                                <i data-lucide="pencil" size="15"></i>
                            </a>
                            <a href="/campagne/report/{{ campaign.id }}" class="icon-btn" title="Rapport">
                                <i data-lucide="download" size="15"></i>
                            </a>
                        </div>
                    </div>
                    <h3 class="campaign-card-title">{{ campaign.name }}</h3>
                    <div class="campaign-card-progress">
                        <div class="progress-row">
                            <span class="progress-text">{{ campaign.responded_count }} van {{ campaign.total_members }} gereageerd</span>
                            <span class="progress-pct">{{ campaign.response_pct }}%</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill-bar fill-{% if campaign.status == 'active' %}active{% elseif campaign.status == 'completed' %}completed{% else %}draft{% endif %}" style="width: {{ campaign.response_pct }}%"></div>
                        </div>
                    </div>
                    <div class="campaign-card-footer">
                        <span class="footer-warning">
                            <i data-lucide="alert-triangle" size="14"></i>
                            {{ campaign.total_members - campaign.responded_count }} nog niet gereageerd
                        </span>
                        <a href="/campagne/view/{{ campaign.id }}" class="campaign-card-link">Bekijken <i data-lucide="arrow-right" size="14"></i></a>
                    </div>
                </div>
            {% else %}
                <div class="campaign-card" style="grid-column: 1 / -1; text-align: center; padding: 4rem; display: flex; flex-direction: column; align-items: center; justify-content: center; background: white; border: 2px dashed #e2e8f0;">
                    <div style="margin-bottom: 1.5rem; background: #f8fafc; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                         <i data-lucide="inbox" size="40" style="color: #94a3b8;"></i>
                    </div>
                    <h3 style="margin-bottom: 0.5rem; color: #1e293b; font-size: 1.25rem;">Geen campagnes gevonden</h3>
                    <p style="color: #64748b; margin-bottom: 2rem; max-width: 400px;">U heeft nog geen campagnes aangemaakt. Begin met uw eerste campagne om toestemming te verzamelen.</p>
                    <a href="/campagne/nieuw" class="btn btn-primary" style="display: inline-flex; width: auto; padding: 0.75rem 2rem; align-items: center; gap: 0.5rem;">
                        <i data-lucide="plus" size="20"></i>
                        <span>Start uw eerste campagne</span>
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{% endblock %}

{% block scripts %}
<script>
    const sidebar         = document.getElementById('sidebar');
    const backdrop        = document.getElementById('sidebarBackdrop');
    const openBtn         = document.getElementById('mobileMenuBtn');
    const closeBtn        = document.getElementById('sidebarCloseBtn');

    function openSidebar() {
        sidebar.classList.add('sidebar-open');
        backdrop.classList.add('backdrop-visible');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        sidebar.classList.remove('sidebar-open');
        backdrop.classList.remove('backdrop-visible');
        document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', openSidebar);
    closeBtn?.addEventListener('click', closeSidebar);
    backdrop?.addEventListener('click', closeSidebar);
</script>
{% endblock %}

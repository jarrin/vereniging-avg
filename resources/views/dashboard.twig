{% extends 'layout.twig' %}

{% block content %}
	<div class="dashboard-header">
		<div class="dashboard-container">
			<div class="dashboard-top">
				<div class="dashboard-title-section">
					<h1 class="dashboard-title">Dashboard</h1>
					<p class="dashboard-subtitle">Beheer uw toestemmingscampagnes</p>
				</div>
				<div class="dashboard-actions">
					<a href="/campagne/nieuw" class="btn btn-primary btn-new-campaign">
						<i data-lucide="plus" size="20"></i>
						Nieuwe campagne
					</a>
				</div>
			</div>
		</div>
	</div>

	<div class="dashboard-stats">
		<div class="dashboard-container">
			<div class="stats-grid">
				<div class="stat-box">
					<div class="stat-icon icon-gray">
						<i data-lucide="users"></i>
					</div>
					<div class="stat-content">
						<p class="stat-label">Totaal leden</p>
						<p class="stat-number">365</p>
					</div>
				</div>

				<div class="stat-box">
					<div class="stat-icon icon-green">
						<i data-lucide="check-circle"></i>
					</div>
					<div class="stat-content">
						<p class="stat-label">Gereageerd</p>
						<p class="stat-number">307</p>
					</div>
				</div>

				<div class="stat-box">
					<div class="stat-icon icon-green">
						<i data-lucide="mail"></i>
					</div>
					<div class="stat-content">
						<p class="stat-label">Actieve Campagnes</p>
						<p class="stat-number">1</p>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

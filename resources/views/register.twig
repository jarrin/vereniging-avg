{% extends "layout.twig" %}

{% block content %}
<div class="center-container">
    <div class="auth-form register-form">
        <h2>Account Aanmaken</h2>
        <p>Maak een account aan om campagnes te beheren</p>
        
        {% if message %}
            <div class="message {% if messageType == 'success' %}success{% else %}error{% endif %}">
                {{ message }}
            </div>
        {% endif %}

        <form method="post" action="" novalidate>
            <div class="form-group">
                {% if fieldErrors.username %}
                    <div class="field-error">{{ fieldErrors.username }}</div>
                {% endif %}
                <label for="username">Gebruikersnaam</label>
                <input 
                    id="username" 
                    name="username" 
                    type="text" 
                    required 
                    maxlength="255"
                    value="{{ post.username|default('') }}"
                    placeholder="Kies een unieke gebruikersnaam"
                />
            </div>

            <div class="form-group">
                {% if fieldErrors.email %}
                    <div class="field-error">{{ fieldErrors.email }}</div>
                {% endif %}
                <label for="email">E-mailadres</label>
                <input 
                    id="email" 
                    name="email" 
                    type="email" 
                    required 
                    maxlength="255"
                    value="{{ post.email|default('') }}"
                    placeholder="Voer uw e-mailadres in"
                />
            </div>

            <div class="form-group">
                {% if fieldErrors.password %}
                    <div class="field-error">{{ fieldErrors.password }}</div>
                {% endif %}
                <label for="password">Wachtwoord</label>
                <input 
                    id="password" 
                    name="password" 
                    type="password" 
                    required 
                    minlength="8"
                    placeholder="Minimaal 8 tekens"
                />
                <small>Minimaal 8 tekens</small>
            </div>

            <div class="form-group">
                {% if fieldErrors.password_confirm %}
                    <div class="field-error">{{ fieldErrors.password_confirm }}</div>
                {% endif %}
                <label for="password_confirm">Bevestig wachtwoord</label>
                <input 
                    id="password_confirm" 
                    name="password_confirm" 
                    type="password" 
                    required
                    placeholder="Herhaal uw wachtwoord"
                />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Account Aanmaken</button>
            </div>
        </form>

        <div class="auth-footer">
            <p>Heeft u al een account? <a href="/index.php?action=login">Log hier in</a></p>
        </div>
    </div>
</div>
{% endblock %}

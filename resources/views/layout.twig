<!DOCTYPE html>
<html lang="nl">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title|default('AVG Verenigingen') }}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg">
		<link rel="stylesheet" href="/css/style.css">
		<script src="https://unpkg.com/lucide@latest"></script>
	</head>
	<body class="{% block bodyClass %}{% endblock %}">
		<!-- Loading Overlay -->
		<div id="loading-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #f9fafb; z-index: 9999; display: flex; justify-content: center; align-items: center; transition: opacity 0.5s;">
			<div class="loader-spinner" style="width: 50px; height: 50px; border: 4px solid rgba(20, 184, 166, 0.1); border-top-color: #14b8a6; border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
		</div>
		<style> @keyframes spin { 100% { transform: rotate(360deg); } } </style>

		{% block navbar %}
			{% include 'includes/navbar.twig' %}
		{% endblock %}

		<main>
			{% block content %}{% endblock %}
		</main>

		{% block footer %}
			{% include 'includes/footer.twig' %}
		{% endblock %}

		<!-- GSAP -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script>
			lucide.createIcons();

			const menuToggle = document.querySelector('.menu-toggle');
			const navLinks = document.querySelector('.nav-links');

			if (menuToggle && navLinks) {
				menuToggle.addEventListener('click', () => {
					navLinks.classList.toggle('active');
					const icon = menuToggle.querySelector('i');
					if (navLinks.classList.contains('active')) {
						icon.setAttribute('data-lucide', 'x');
					} else {
						icon.setAttribute('data-lucide', 'menu');
					}
					lucide.createIcons();
				});
			}

			// GSAP Animations
			document.addEventListener("DOMContentLoaded", () => {
				const tl = gsap.timeline();
				
				// 1. Fade out preloader
				tl.to("#loading-overlay", {
					opacity: 0,
					duration: 0.5,
					ease: "power2.out",
					onComplete: () => {
						const overlay = document.getElementById("loading-overlay");
						if (overlay) overlay.remove();
					}
				});

				// 2. Animate Navbar
				tl.from(".navbar", {
					y: -50,
					opacity: 0,
					duration: 0.6,
					ease: "power2.out"
				}, "-=0.2");

				// 3. Animate Main Content Items (Direct children of <main>)
				// Dit voorkomt dat geneste animaties op <main> en children elkaar in de weg zitten
				const mainItems = document.querySelectorAll('main > *');
				if (mainItems.length > 0) {
					tl.from(mainItems, {
						y: 30,
						opacity: 0,
						duration: 0.7,
						stagger: 0.2,
						ease: "power2.out"
					}, "-=0.3");
				}

				// 4. Animate Footer
				tl.from(".footer", {
					opacity: 0,
					y: 20,
					duration: 0.6,
					ease: "power2.out"
				}, "-=0.2");
			});
		</script>

		{% block scripts %}{% endblock %}

		<!-- Pseudo-Cron trigger: Achtergrondtaken zonder bash server toegang! -->
		<script>
			setTimeout(() => {
				fetch('/run-cron?secret=avg_secret_123').catch(e => console.log('Cron err', e));
			}, 3000); // 3 seconden vertraging
		</script>
	</body>
</html>

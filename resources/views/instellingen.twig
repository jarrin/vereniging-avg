{% extends 'layout.twig' %}

{% block bodyClass %}page-dashboard{% endblock %}
{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block content %}

<!-- Mobile topbar (only visible on small screens) -->
<div class="mobile-topbar">
    <div class="mobile-topbar-brand">
        <i data-lucide="shield-check"></i>
        <span>AVG Verenigingen</span>
    </div>
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu openen">
        <i data-lucide="menu"></i>
    </button>
</div>

<!-- Sidebar overlay backdrop -->
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<div class="app-shell">

    <!-- Sidebar -->
    {% include 'includes/sidebar.twig' with {'active_page': 'settings'} %}


    <!-- Main content -->
    <div class="main-content">

        <!-- Top bar -->
        <div class="topbar">
            <div class="topbar-left">
                <h1 class="topbar-title">Instellingen</h1>
                <p class="topbar-subtitle">Pas uw account en beveiliging aan</p>
            </div>
        </div>

        <!-- Settings container -->
        <div class="settings-container">
            
            <div class="settings-section">
                <div class="settings-header">
                    <h2 class="settings-title">Verenigingsprofiel</h2>
                    <p class="settings-desc">Pas uw verenigingsgegevens aan voor gebruik in e-mails.</p>
                </div>
                <div class="settings-card">
                    <form method="post" action="/instellingen/update-profile" class="settings-form" enctype="multipart/form-data">
                        <div class="form-group row mb-4">
                            <div class="col-half">
                                <label for="username">Verenigingsnaam</label>
                                <input type="text" id="username" name="username" class="campaign-form-input" value="{{ user.username|default('') }}">
                                <small class="form-hint">Deze naam wordt getoond in e-mails.</small>
                            </div>
                            <div class="col-half">
                                <label for="email">E-mailadres (Beheer)</label>
                                <input type="email" id="email" name="email" class="campaign-form-input" value="{{ user.email|default('') }}">
                            </div>
                        </div>
                        <div class="form-group row mb-4">
                            <div class="col-half">
                                <label for="contact_person">Contactpersoon</label>
                                <input type="text" id="contact_person" name="contact_person" class="campaign-form-input" value="{{ user.contact_person|default('') }}" placeholder="Bijv. de secretaris">
                            </div>
                            <div class="col-half">
                                <label for="phone">Telefoonnummer</label>
                                <input type="text" id="phone" name="phone" class="campaign-form-input" value="{{ user.phone|default('') }}">
                            </div>
                        </div>
                        <div class="form-group mb-4">
                            <div class="checkbox-wrapper">
                                <input type="checkbox" id="use_phone" name="use_phone" value="1" {{ user.use_phone ? 'checked' : '' }}>
                                <label for="use_phone">Telefoonnummer tonen aan leden</label>
                            </div>
                        </div>
                        <div class="form-group mb-4">
                            <label for="logo">Verenigingslogo (.jpg)</label>
                            {% if user.logo_path %}
                                <div class="current-logo mb-2" style="margin-bottom: 1rem;">
                                    <img src="{{ user.logo_path }}" alt="Huidig logo" style="max-height: 80px; border: 1px solid #ddd; border-radius: 4px; padding: 4px;">
                                    <p class="form-hint" style="font-size: 0.75rem;">Huidig logo</p>
                                </div>
                            {% endif %}
                            <input type="file" id="logo" name="logo" class="campaign-form-input" accept=".jpg,.jpeg">
                            <small class="form-hint">Het logo moet een JPG bestand zijn.</small>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Profiel bijwerken</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="settings-section">
                <div class="settings-header">
                    <h2 class="settings-title">Wachtwoord veranderen</h2>
                    <p class="settings-desc">Kies een sterk wachtwoord om uw account veilig te houden.</p>
                </div>
                <div class="settings-card">
                    <form method="post" action="#" class="settings-form">
                        <div class="form-group mb-4">
                            <label for="current_password">Huidig wachtwoord</label>
                            <input type="password" id="current_password" name="current_password" class="campaign-form-input" placeholder="••••••••">
                        </div>
                        <div class="form-group row mb-4">
                            <div class="col-half">
                                <label for="new_password">Nieuw wachtwoord</label>
                                <input type="password" id="new_password" name="new_password" class="campaign-form-input" placeholder="••••••••">
                            </div>
                            <div class="col-half">
                                <label for="confirm_password">Bevestig nieuw wachtwoord</label>
                                <input type="password" id="confirm_password" name="confirm_password" class="campaign-form-input" placeholder="••••••••">
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Wachtwoord wijzigen</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="settings-section danger-zone">
                <div class="settings-header">
                    <h2 class="settings-title delete-title">Gevarenzone</h2>
                    <p class="settings-desc">Permanente acties voor uw account.</p>
                </div>
                <div class="settings-card border-danger">
                    <div class="danger-flex">
                        <div class="danger-text">
                            <h3>Account verwijderen</h3>
                            <p>Zodra u uw account verwijdert, is er geen weg meer terug. Wees alsjeblieft heel zeker.</p>
                        </div>
                        <button class="btn icon-btn-danger btn-delete">Verwijder account</button>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

{% block scripts %}
<script>
    const sidebar         = document.getElementById('sidebar');
    const backdrop        = document.getElementById('sidebarBackdrop');
    const openBtn         = document.getElementById('mobileMenuBtn');
    const closeBtn        = document.getElementById('sidebarCloseBtn');

    function openSidebar() {
        sidebar.classList.add('sidebar-open');
        backdrop.classList.add('backdrop-visible');
        document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
        sidebar.classList.remove('sidebar-open');
        backdrop.classList.remove('backdrop-visible');
        document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', openSidebar);
    closeBtn?.addEventListener('click', closeSidebar);
    backdrop?.addEventListener('click', closeSidebar);
</script>
{% endblock %}
{% endblock %}
